{
  "name": "robomaster-client-native",
  "productName": "RoboMaster 2026 Client",
  "version": "1.0.0",
  "description": "RoboMaster 2026 客户端 - 用于对接 SharkDataSever 服务端",
  "main": "dist/main/index.js",
  "private": true,
  "scripts": {
    "start": "npm run build && electron .",
    "build": "webpack --config webpack.main.config.ts && webpack --config webpack.preload.config.ts && webpack --config webpack.renderer.config.ts",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "lint": "eslint --ext .ts,.tsx ."
  },
  "build": {
    "appId": "com.robomaster.client",
    "productName": "RoboMaster 2026 Client",
    "asar": true,
    "directories": {
      "output": "out"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "resources/**/*",
      "package.json"
    ],
    "win": {
      "target": ["nsis", "zip"],
      "icon": "resources/ZHUXI.ico",
      "executableName": "RoboMasterClient"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "resources/ZHUXI.ico",
      "uninstallerIcon": "resources/ZHUXI.ico",
      "shortcutName": "RoboMaster 2026 Client",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    }
  },
  "keywords": [],
  "author": {
    "name": "Your Name",
    "email": "you@example.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron/fuses": "^1.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vercel/webpack-asset-relocator-loader": "^1.7.3",
    "css-loader": "^6.11.0",
    "electron": "40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "fork-ts-checker-webpack-plugin": "^7.3.0",
    "html-webpack-plugin": "^5.6.6",
    "node-loader": "^2.1.0",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "typescript": "~4.5.4",
    "webpack": "^5.105.4",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^11.0.2",
    "jsmpeg-player": "^3.0.3",
    "mqtt": "^5.15.0",
    "protobufjs": "^8.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.11"
  }
}
